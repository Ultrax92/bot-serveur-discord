# Copie ce fichier en .env et remplis les valeurs (ne partage JAMAIS ton token)
# Token du bot : https://discord.com/developers/applications → ton app → Bot → Reset Token
DISCORD_TOKEN=

# Application ID : https://discord.com/developers/applications → ton app → General Information
CLIENT_ID=

# Ton ID Discord (clic droit sur ton profil → Copier l'identifiant de l'utilisateur)
# = owner du bot : accès total à toutes les commandes, seul à pouvoir gérer /get-admin et /del-admin
OWNER_ID=

# ID de ton serveur Discord (clic droit sur le serveur → Copier l'identifiant du serveur)
# Si renseigné : les commandes se déploient instantanément sur ce serveur uniquement (recommandé)
# Si vide : déploiement global (jusqu'à 1h de propagation)
GUILD_ID=
